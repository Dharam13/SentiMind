# Collector Service Environment Variables
PORT=8005
NODE_ENV=development

# Database Configuration (MongoDB)
MONGODB_URI=mongodb://localhost:27017/sentimind
MONGODB_DB_NAME=sentimind

# Queue Configuration (Amazon SQS)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/sentiment-queue

# API Keys
NEWS_API_KEY=your-news-api-key
YOUTUBE_API_KEY=your-youtube-api-key
TWITTER_BEARER_TOKEN=your-twitter-bearer-token
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret

# Collection Configuration
LOOKBACK_HOURS=48
DEDUPLICATION_ENABLED=true
