# Auth Service Environment Variables
PORT=8001
NODE_ENV=development

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/sentimind_auth
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sentimind_auth
DB_USER=user
DB_PASSWORD=password

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# Bcrypt
BCRYPT_ROUNDS=10
