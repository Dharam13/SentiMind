# Sentiment Service Environment Variables
PORT=8006
NODE_ENV=development

# Database Configuration (MongoDB)
MONGODB_URI=mongodb://localhost:27017/sentimind
MONGODB_DB_NAME=sentimind

# Queue Configuration (Amazon SQS)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/sentiment-queue

# Model Configuration
USE_BERT=true
BERT_MODEL_NAME=bert-base-uncased
CONFIDENCE_THRESHOLD=0.7
BATCH_SIZE=32
