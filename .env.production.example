# ===========================================
# SentiMind Production Environment Template
# ===========================================
# Copy to .env and fill in your values.
# For AWS: set VITE_API_GATEWAY_URL to http://EC2_PUBLIC_IP or https://yourdomain.com

########################################
# MongoDB Atlas (required)
########################################
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/sentimind_collector?retryWrites=true&w=majority

########################################
# PostgreSQL (Docker internal)
########################################
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/auth_db

########################################
# Auth Service
########################################
JWT_SECRET=<generate-strong-random-secret>
JWT_ACCESS_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRY_DAYS=7
CORS_ORIGINS=http://localhost,http://localhost:80

########################################
# API Gateway (Docker internal - no change needed)
########################################
# AUTH_SERVICE_URL, COLLECTOR_SERVICE_URL, SENTIMENT_SERVICE_URL are set in docker-compose

########################################
# Collector Service
########################################
SENTIMENT_SERVICE_URL=http://sentiment-service:8030

########################################
# Frontend build (set before: docker compose build)
########################################
# For local: http://localhost
# For AWS: http://EC2_PUBLIC_IP or https://yourdomain.com
VITE_API_GATEWAY_URL=http://localhost

########################################
# Collector Tuning (optional - have sensible defaults)
########################################
# SENTIMENT_PROCESSOR_ENABLED=true
# COLLECTOR_DEFAULT_HOURS=24

########################################
# External API Keys (optional - for collection features)
########################################
# Twitter / X
# TWITTER_API_KEY=
# TWITTER_BEARER_TOKEN=
# TWITTER_API_SECRET=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_SECRET=

# Reddit
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_USER_AGENT=SentiMind/1.0

# YouTube
# YOUTUBE_API_KEY=

# News APIs
# NEWSAPI_KEY=
# GNEWS_API_KEY=
# NEWSDATA_API_KEY=

# Google Custom Search
# GOOGLE_API_KEY=
# GOOGLE_SEARCH_CX=

# Tumblr
# TUMBLR_API_KEY=
