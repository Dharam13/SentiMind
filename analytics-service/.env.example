# Analytics Service Environment Variables
PORT=8003
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/sentimind
MONGODB_DB_NAME=sentimind
POSTGRESQL_URL=postgresql://user:password@localhost:5432/sentimind_keywords

# Cache Configuration
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=300

# Analytics Configuration
TREND_WINDOW_DAYS=30
INFLUENCER_SCORE_THRESHOLD=0.5
